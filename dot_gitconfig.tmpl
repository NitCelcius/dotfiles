[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[user]
	name = NitCelcius
	email = nitcelcius@nitcelcius.me
	signingkey = {{ (bitwarden "item" "b70567a7-5d86-4db3-8741-b34200f283b4").sshKey.publicKey }}
[core]
	editor = code --wait
[commit]
	gpgsign = true
[rerere]
	enabled = true
[gpg]
	format = ssh
[push]
	autoSetupRemote = true
[alias]
	s = status
	d = diff
	a = add
	cm = commit -m
	ca = commit --amend
	co = checkout
	cb = checkout -b
	sw = switch
	swc = switch -c
	br = branch
	l = log --oneline --graph --decorate -20
	la = log --oneline --graph --decorate --all
	rc = rebase --continue
	ri = rebase -i
	p = push
	pushf = push --force-with-lease
	pullr = pull --rebase
	unstage = reset HEAD --
	last = log -1 HEAD
	sl = stash list
[include]
	path = ~/.gitconfig.local
